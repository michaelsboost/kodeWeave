  "html": "<app-root>Loading...</app-root>",
  "css": "",
  "javascript": "const { Component, NgModule, enableProdMode } = ng.core;\nconst { BrowserModule } = ng.platformBrowser;\nconst { platformBrowserDynamic } = ng.platformBrowserDynamic;\n\nenableProdMode();\n\n@Component({\n  selector: 'app-root',\n  template: `\n    <div class=\"flex flex-col items-center justify-center absolute inset-0\">\n      <h1 class=\"text-3xl font-thin mb-4\">👋 Hello, Angular 11! 🌎</h1>\n      <p class=\"text-xl mb-4\">Counter: <span id=\"counter\" class=\"font-mono\">{{ counter }}</span></p>\n      <div class=\"grid grid-cols-2 gap-4\">\n        <button\n          id=\"incrementButton\"\n          class=\"px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-700 transition\"\n          (click)=\"decrementCounter()\"\n        >\n          -\n        </button>\n        <button\n          id=\"incrementButton\"\n          class=\"px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-700 transition\"\n          (click)=\"incrementCounter()\"\n        >\n          +\n        </button>\n      </div>\n    </div>\n  `,\n})\nclass AppComponent {\n  counter = 0;\n  \n  incrementCounter() {\n    this.counter++;\n  }\n  decrementCounter() {\n    this.counter--;\n  }\n}\n\n@NgModule({\n  declarations: [AppComponent],\n  imports: [BrowserModule],\n  bootstrap: [AppComponent]\n})\nclass AppModule {}\n\nplatformBrowserDynamic().bootstrapModule(AppModule);",
